@model Accounts.Models.ViewModels.LoginViewModel

@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Iniciar sesión";

    var descLink = ViewData["DescLink"] == null ? "" : ViewData["DescLink"].ToString();
}

<h1>Iniciar sesión</h1>
<p class="text-muted mt-sm" style="margin-bottom:1.5rem;">Ingresa tus credenciales para acceder a tu cuenta.</p>

<form asp-action="UserLogin">
    <div asp-validation-summary="ModelOnly"></div>

    <div class="field">
        <label asp-for="Email" class="label"></label>
        <input asp-for="Email" class="input" autocomplete="email" />
        <span asp-validation-for="Email"></span>
    </div>

    <div class="field">
        <label asp-for="Password" class="label"></label>
        <input type="password" asp-for="Password" class="input" autocomplete="current-password" />
        <span asp-validation-for="Password"></span>
    </div>

    <button type="submit" class="btn btn-primary btn-block">Entrar</button>

    <p class="auth-foot" style="margin-bottom:0;">
        @Html.ActionLink("¿Has olvidado tu contraseña?", "ForgottenPassword", "Login", null)
    </p>

    <input type="hidden" name="Sistema" value="@descLink" />
</form>

<div class="auth-foot">
    ¿Aún no tienes una cuenta?
    @Html.ActionLink("Crea una cuenta", "Create", "User", new { sistema = descLink }, null)
</div>

@if (!string.IsNullOrEmpty(descLink))
{
    <div class="auth-foot">
        @Html.ActionLink(descLink, "GetToken", "Login", new { pProgram = descLink, pEmail = Model.Email }, null)
    </div>
}
