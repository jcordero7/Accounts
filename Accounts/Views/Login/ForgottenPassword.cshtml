@{
    Layout = "_LayoutAuth";
    ViewData["Title"] = "Recuperar contraseña";
}

<h1>Recuperar contraseña</h1>

<div id="section-email">
    <p class="text-muted mt-sm" style="margin-bottom:1.25rem;">Ingresa tu correo y te enviaremos un código para restablecer tu contraseña.</p>

    <div class="field">
        <label class="label" for="txtEmail">Correo electrónico</label>
        <div class="input-group">
            <input type="email" id="txtEmail" class="input" placeholder="usuario@ejemplo.com">
            <button type="button" class="btn btn-primary" onclick="requestResetCode()">Enviar</button>
        </div>
    </div>

    <div id="msgContainerEmail"></div>
</div>

<div id="section-code" class="mt-lg" style="display: none;">
    <div class="field">
        <label class="label" for="txtCode">Código de verificación</label>
        <div class="input-group">
            <input type="text" id="txtCode" class="input" placeholder="123456">
            <button type="button" class="btn btn-primary" onclick="verifyCode()">Validar</button>
        </div>
    </div>

    <div id="msgContainerCode"></div>

    <div class="mt-md">
        <button id="btnReenviarCodigo" class="btn btn-secondary" type="button">
            Enviar código de activación
        </button>

        <div id="contenedorContador" class="help-text" style="display: none;">
            Podrás solicitar un nuevo código en: <strong id="contador">60</strong> segundos.
        </div>
    </div>
</div>

<p class="auth-foot">
    @Html.ActionLink("Volver a iniciar sesión", "UserLogin", "Login", null)
</p>

@section Scripts {
<script>
    $(document).ready(function () {
        $('#btnReenviarCodigo').on('click', function () {
            var email = $('#txtEmail').val();
            enviarCodigoPorAjax(email);
            iniciarContador(60);
        });
    });

    function requestResetCode() {
        var email = $('#txtEmail').val();

        $.post('/Login/ForgottenPasswordRecover', { email: email }, function (response) {
            if (response) {
                $('#section-email').hide();
                $('#section-code').show();
                $('#msgContainerCode').html('<div class="alert alert-info">Código enviado a tu correo.</div>');

                iniciarContador(60);
            } else {
                $('#msgContainerCode').html('<div class="alert alert-danger">' + response.message + '</div>');
            }
        });
    }

    function verifyCode() {
        var code = $('#txtCode').val();
        var email = $('#txtEmail').val();

        $.post('/Login/ResetPassword', { email: email, token: code }, function (response) {
            if (response) {
                alert("Contraseña cambiada correctamente, la hemos enviado a tu correo.");
                window.location.href = '/Login/UserLogin?sistema=';
            } else {
                $('#msgContainerCode').html('<div class="alert alert-danger">Código incorrecto o expirado.</div>');
            }
        });
    }

    function iniciarContador(segundosTotales) {
        var $btn = $('#btnReenviarCodigo');
        var $contenedor = $('#contenedorContador');
        var $contador = $('#contador');
        var tiempoRestante = segundosTotales;

        $btn.prop('disabled', true).text('Código enviado');
        $contador.text(tiempoRestante);
        $contenedor.fadeIn();

        var temporizador = setInterval(function () {
            tiempoRestante--;
            $contador.text(tiempoRestante);

            if (tiempoRestante <= 0) {
                clearInterval(temporizador);
                $btn.prop('disabled', false).text('Reenviar código');
                $contenedor.fadeOut();
            }
        }, 1000);
    }

    function enviarCodigoPorAjax(email) {
        var data = { email: email };

        $.ajax({
            url: '/Login/ReenviarCodigoForgot',
            type: 'GET',
            data: data,
            success: function (result) {
                if (result) {
                    alert("Código enviado con éxito");
                } else {
                    alert("No se pudo enviar el código");
                }
            }
        });
    }
</script>
}
